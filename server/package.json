{
   "name": "tetrode-backend",
   "packageManager": "pnpm@10.6.5",
   "scripts": {
      "dev": "nodemon",
      "dev:prod-env": "ENV_FILE=.env.production nodemon",
      "start": "node dist/server.js",
      "prod": "ENV_FILE=.env.production node dist/server.js",
      "build": "NODE_OPTIONS=--max-old-space-size=4096 tsc",
      "db:up": "docker compose up -d postgres",
      "db:down": "docker compose down",
      "db:logs": "docker compose logs -f postgres",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
      "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx --fix",
      "agent:test": "ts-node src/scripts/test-opencode-agent.ts",
      "mcp:test": "ts-node src/scripts/test-mcp.ts",
      "mcp:start": "tsx src/mcp.ts",
      "agent:delete-all": "ts-node src/scripts/delete-all-agents.ts",
      "comments:reply": "ts-node src/scripts/reply-comments.ts",
      "env:sync:production": "bash ./scripts/sync-prod-env.sh",
      "generate": "pnpm exec prisma generate",
      "migrate": "pnpm exec prisma migrate dev",
      "games:seed": "ts-node src/scripts/seed-games.ts",
      "agents:seed": "ts-node src/scripts/seed-agents.ts",
      "agents:mint": "ts-node src/scripts/mint-agents-erc8004.ts",
      "passes:backfill": "ts-node src/scripts/backfill-free-passes.ts",
      "agents:update-uris": "ts-node src/scripts/update-agent-uris.ts",
      "studio": "pnpm exec prisma studio",
      "validate-api": "tspec validate",
      "seed:reports": "ts-node src/scripts/seed-reports.ts",
      "pipeline:run:all": "pnpm pipeline:run && pnpm comments:reply"
   },
   "prisma": {
      "schema": "./prisma/schema"
   },
   "dependencies": {
      "@json2csv/node": "^7.0.6",
      "@modelcontextprotocol/sdk": "^1.29.0",
      "@opencode-ai/sdk": "^1.15.0",
      "@prisma/client": "^6.19.1",
      "@privy-io/node": "^0.18.0",
      "@types/js-yaml": "^4.0.9",
      "@types/pdfkit": "^0.17.3",
      "@types/puppeteer": "^5.4.7",
      "@types/xlsx": "^0.0.35",
      "bcrypt": "^6.0.0",
      "chalk": "^5.6.2",
      "cloudinary": "^2.8.0",
      "cors": "^2.8.5",
      "dotenv": "^16.5.0",
      "express": "^5.1.0",
      "express-rate-limit": "^8.2.1",
      "fast-xml-parser": "^4.5.0",
      "google-auth-library": "^10.5.0",
      "helmet": "^8.1.0",
      "morgan": "^1.10.0",
      "multer": "^1.4.5-lts.2",
      "nodemailer": "^7.0.12",
      "pdfkit": "^0.17.2",
      "pino": "^9.6.0",
      "prisma": "^6.19.1",
      "puppeteer": "^24.29.1",
      "resend": "^6.4.2",
      "sharp": "^0.34.1",
      "socket.io": "^4.8.3",
      "swagger-jsdoc": "^6.2.8",
      "swagger-ui-express": "^5.0.1",
      "text-to-svg": "^3.1.5",
      "tspec": "^0.1.116",
      "viem": "^2.50.4",
      "xlsx": "^0.18.5",
      "zod": "^3.24.4",
      "zod-validation-error": "^3.5.2"
   },
   "devDependencies": {
      "@types/bcrypt": "^6.0.0",
      "@types/cors": "^2.8.17",
      "@types/dotenv": "^8.2.3",
      "@types/express": "^5.0.1",
      "@types/helmet": "^4.0.0",
      "@types/morgan": "^1.9.9",
      "@types/multer": "^1.4.13",
      "@types/node": "^22.15.3",
      "@types/nodemailer": "^6.4.17",
      "@types/swagger-jsdoc": "^6.0.4",
      "@types/swagger-ui-express": "^4.1.8",
      "@types/text-to-svg": "^3.1.4",
      "@typescript-eslint/eslint-plugin": "^8.32.0",
      "@typescript-eslint/parser": "^8.32.0",
      "esbuild": "^0.28.0",
      "eslint": "^9.26.0",
      "nodemon": "^3.1.10",
      "prettier": "^3.6.2",
      "ts-node": "^10.9.2",
      "tsx": "^4.20.6",
      "typescript": "^5.8.3"
   }
}
