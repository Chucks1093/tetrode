enum RoomStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum ParticipantType {
  HUMAN
  AI
}

model Room {
  id           String        @id @default(cuid())
  publicId     String        @unique @default(uuid())
  gameId       String
  status       RoomStatus    @default(WAITING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  participants Participant[]
  messages     ChatMessage[]
  votes        Vote[]

  @@index([gameId, status])
}

model Participant {
  id          String          @id @default(cuid())
  publicId    String          @unique @default(uuid())
  roomId      String
  type        ParticipantType
  displayName String
  actorId       String
  walletAddress String?
  joinedAt      DateTime        @default(now())
  room        Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]
  votesGiven  Vote[]          @relation("VoterVotes")
  votesReceived Vote[]        @relation("TargetVotes")

  @@index([roomId])
  @@index([actorId])
}

model Vote {
  id                  String      @id @default(cuid())
  roomId              String
  voterParticipantId  String
  targetParticipantId String
  createdAt           DateTime    @default(now())

  room    Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  voter   Participant @relation("VoterVotes", fields: [voterParticipantId], references: [id], onDelete: Cascade)
  target  Participant @relation("TargetVotes", fields: [targetParticipantId], references: [id], onDelete: Cascade)

  @@unique([roomId, voterParticipantId])
  @@index([roomId])
}
