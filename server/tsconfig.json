{
   "compilerOptions": {
      "target": "ES2022",
      "module": "commonjs",
      "lib": ["ES2022"],
      "allowJs": true,
      "outDir": "dist",
      "rootDir": "src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "noUnusedLocals": false, // Disable TS unused locals check
      "noUnusedParameters": false // Disable TS unused params check
   },
   "include": ["src/**/*"],
   "exclude": ["node_modules", "src/scripts"]
}
